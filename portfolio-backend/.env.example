# Local dev server port
PORT=8000

# Your deployed frontend URL, used for CORS. Use * for local testing.
FRONTEND_URL=http://localhost:5173

# ── Contact form email (Nodemailer / Gmail) ─────────────────────────────
# Gmail address that SENDS the emails, and its 16-character Gmail "App
# Password" (NOT your normal Gmail password). Create one at:
# https://myaccount.google.com/apppasswords (requires 2-Step Verification).
SMTP_USER=your-email@gmail.com
SMTP_PASS=

# Where contact-form submissions get delivered. Defaults to SMTP_USER if unset.
NOTIFY_EMAIL=your-email@gmail.com

# ── Admin panel auth ─────────────────────────────────────────────────────
# Login email for /admin on the frontend.
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
# Random long secret used to sign admin login tokens (JWT). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-random-64-char-hex-string

# ── Optional: GitHub API token ───────────────────────────────────────────
# The Open Source Activity section calls GitHub's public API unauthenticated
# by default (60 requests/hour per IP — fine for normal traffic, cached for
# 1 hour server-side). If you hit rate limits, create a token with no scopes
# at https://github.com/settings/tokens and set it here for a 5,000/hour limit.
GITHUB_TOKEN=

# ── Image/file uploads (Cloudinary) ──────────────────────────────────────
# REQUIRED for the admin panel's upload/media library features (project
# galleries, certificate images, resume PDF, etc.) — this is what lets
# uploads work correctly even on serverless hosts like Vercel, since files
# are stored on Cloudinary's CDN rather than on the backend's own disk.
#
# Sign up free at https://cloudinary.com (free tier: 25GB storage/bandwidth,
# plenty for a portfolio). After signing in, your Dashboard page shows all
# three values below directly — no separate setup needed.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Optional: content data path (production) ────────────────────────────
# Leave blank for local development — defaults to a folder inside this
# backend directory (already committed to git with your current content).
# This does NOT affect uploaded images (those go to Cloudinary above) —
# it only affects where projects/skills/experience/etc. are read from and
# written to. On Vercel, admin edits to this data won't persist between
# deployments (the filesystem is read-only in production); edit locally
# and git push instead. See the README's Deployment section for details.
DATA_DIR=